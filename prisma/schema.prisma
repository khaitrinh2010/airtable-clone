datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
  bases Base[]
}

model Base {
  id      String  @id @default(uuid())
  name    String
  ownerId String
  owner   User    @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
